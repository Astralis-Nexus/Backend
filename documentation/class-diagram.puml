package "exception" {
    class ApiException extends Exception {
        - final int statusCode
        - final String timeStamp
        + ApiException(int statusCode, String message, String timestamp)
    }
}

' ======================== PERSISTENCE PACKAGE ========================
' Latest updated: 01.05.2025
package "persistence" {
    package "config" {
        class HibernateConfig {
            - {static} EntityManagerFactory entityManagerFactory
            - {static} EntityManagerFactory buildEntityFactoryConfig()
            - {static} EntityManagerFactory setupHibernateConfigurationForTesting()
            - {static} EntityManagerFactory getEntityManagerFactory(Configuration, Properties)
            - {static} void getAnnotationConfiguration(Configuration)
            - {static} EntityManagerFactory getEntityManagerFactoryConfigDevelopment()
            - {static} void getEntityManagerFactoryConfigTest()
            + {static} EntityManagerFactory getEntityManagerFactoryConfig(boolean isTest)
        }
    }
    
    package "model" {
        class Account {
            - String salt
            - int id
            - String username
            - String password
            - Role role
            - List<Todo> todos
            - List<Information> informations
            - List<Game> games
            - List<QA> qas
            + void setPassword(String password)
            + Account(String username, String password, Role role)
            + Account(String username, String password)
            + boolean verifyPassword(String password)
        }
        
        class Role {
            - int id
            - RoleName name
            + Role(RoleName name)
            + enum RoleName { REGULAR, NONE }
        }
        
        class Information {
            - int id
            - String description
            - ImportanceLevel importanceLevel
            - Account account
            + Information(String description, Account account, ImportanceLevel importanceLevel)
            + enum ImportanceLevel {LOW, MEDIUM, HIGH}
        }
        
        class QA {
            - int id
            - String question
            - String answer
            - Account account
            + QA(String question, String answer, Account account)
        }
        
        class Todo {
            - int id
            - LocalDate date
            - String description
            - Status status
            - Source source
            - String done_by
            - Account account
            + Todo(LocalDate date, String description, Status status, Source source, String done_by, Account account)
            + Todo(LocalDate date, String description, Status status, Source source, Account account)
            # void onUpdate()
            - String getCurrentUser()
            # void onCreate()
            + enum Source {GAMEHUB, STORE}
            + enum Status {PENDING, IN_PROGRESS, COMPLETED}
        }
        
        class Game {
            - int id
            - String name
            - Account account
            - List<License> licenses
            + Game(String name, Account account)
            + Game(int id, String name, Account account)
            + Game(int id)
        }
        
        class License {
            - int id
            - String username
            - String password
            - String email
            - int pcNumber
            - LicenseStatus status
            - Game game
            + License(String username, String password, String email, License.LicenseStatus status, Game game)
            + enum LicenseStatus { ACTIVE, INACTIVE }
        }
    }
}

' ======================== ROUTE PACKAGE ========================
' Latest updated: 01.05.2025
package "route" {
    class Route {
        ~ SecurityRoute securityRoute
        ~ AccountRoute accountRoute
        ~ GameRoute gameRoute
        ~ InformationRoute informationRoute
        ~ LicenseRoute licenseRoute
        ~ QARoute qaRoute
        ~ RoleRoute roleRoute
        ~ TodoRoute todoRoute
        + Route(EntityManagerFactory emf)
        + EndpointGroup addRoutes()
    }
    
    class SecurityRoute {
        - final SecurityController securityController
        + SecurityRoute(EntityManagerFactory emf)
        + EndpointGroup authRoutes()
    }
    
    class AccountRoute {
        - final AccountController accountController
        + AccountRoute(EntityManagerFactory emf)
        + EndpointGroup itemRoutes()
    }
    
    class GameRoute {
        - final GameController gameController
        + GameRoute(EntityManagerFactory emf)
        + EndpointGroup itemRoutes()
    }

    class InformationRoute {
        - final InformationController informationController
        + InformationRoute(EntityManagerFactory emf)
        + EndpointGroup itemRoutes()
    }
    
    class LicenseRoute {
        - final LicenseController licenseController
        + LicenseRoute(EntityManagerFactory emf)
        + EndpointGroup itemRoutes()
    }
    
    class QARoute {
        - final QAController qaController
        + QARoute(EntityManagerFactory emf)
        + EndpointGroup itemRoutes()
    }
    
    class RoleRoute {
        - final RoleController roleController
        + RoleRoute(EntityManagerFactory emf)
        + EndpointGroup itemRoutes()
    }
    
    class TodoRoute {
        - final TodoController todoController
        + TodoRoute(EntityManagerFactory emf)
        + EndpointGroup itemRoutes()
    }
}

