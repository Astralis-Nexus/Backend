' ======================== DTO PACKAGE ========================
' Latest updated: 01.05.2025
package "dto" {
    class AccountDTO {
        - int id
        - String username
        - String password
        - Role role
        - List<Todo> todos
        - List<Information> information
        - List<Game> games
        - List<QA> qas
        + AccountDTO(String username, String password)
        + AccountDTO(Account account)
        + Set<String> getRoles()
        + String toString()
    }
    
    class GameDTO {
        - int id
        - String name
        - List<License> licenses
        - int accountID
    }
    
    class InformationDTO {
        - int id
        - String description
        - int accountId
        - String importanceLevel
    }
    
    class LicenseDTO {
        - int id
        - String username
        - String password
        - String email
        - int pcNumber
        - Game game
        - License.LicenseStatus status
    }
    
    class QADTO {
        - int id
        - String question
        - String answer
        - int accountId
    }
    
    class RoleDTO {
        - int id
        - String name
        - List<Header> headers
        - List<Footer> footers
    }
    
    class TodoDTO {
        - int id
        - LocalDate date
        - String description
        - Todo.Status status
        - Todo.Source source
        - String done_by
        - Account account
    }
    
    class TokenDTO {
        - String token
        - String username
        - String role
        - int id
        + String toString()
    }
}

